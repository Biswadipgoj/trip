# TripSplit — Environment Variables
# Copy this file to .env.local and fill in your Supabase project values

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard > Your Project > Settings > API

# Your Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Notes ─────────────────────────────────────────────────────────────────────
# If Supabase vars are not set, the app runs in localStorage-only mode.
# Data will NOT sync across devices but the app will still work for single users.
# Set these in Vercel dashboard: Project > Settings > Environment Variables
