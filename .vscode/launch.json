{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach",
      "port": 9229,
      "request": "attach",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "type": "node"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "▶ Run Next.js Dev Server",
      "runtimeExecutable": "C:\\Program Files\\nodejs\\node.exe",
      "runtimeArgs": ["node_modules/.bin/next", "dev"],
      "cwd": "${workspaceFolder}",
      "env": {},
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "▶ Run Next.js Dev (nvm)",
      "runtimeExecutable": "${env:NVM_SYMLINK}\\node.exe",
      "runtimeArgs": ["node_modules/.bin/next", "dev"],
      "cwd": "${workspaceFolder}",
      "env": {},
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}